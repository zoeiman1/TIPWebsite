      ],
      "source": [
        "unscaled_y_test = robust_scaler.inverse_transform(y_test.reshape(-1, look_back))\n",
        "unscaled_LSTM_y_pred = robust_scaler.inverse_transform(LSTM_y_pred)\n",
        "mae = mean_absolute_error(unscaled_y_test, unscaled_LSTM_y_pred)\n",
